# Backend environment configuration — copy to `.env` and fill in real values.
# Loaded by config.py (pydantic-settings). NEVER commit a real `.env`.

# --- Auth (REQUIRED) ---
# Must be a strong, deployment-specific value. The app refuses to boot if this
# is missing or left at the "change-me-before-production" default.
AUTH_SECRET_KEY=
AUTH_TOKEN_TTL_SECONDS=86400

# --- Database ---
# Defaults to local sqlite if unset. Use a Postgres/Supabase URL in production.
DATABASE_URL=sqlite:///./esim_access.db

# --- API docs ---
# Serve /docs, /redoc and /openapi.json. Secure-by-default: keep false in
# production — the docs enumerate the full admin/payment API surface to
# anonymous visitors. Set true for local development.
API_DOCS_ENABLED=false

# --- eSIM Access provider (REQUIRED) ---
ESIM_ACCESS_ACCESS_CODE=
ESIM_ACCESS_SECRET_KEY=
# Shared secret guarding the eSIM Access lifecycle webhook. Set the SAME value in
# the eSIM Access dashboard's webhook URL (the provider sends it back so we can
# authenticate the callback). Rotate periodically and keep it out of access logs.
# Generate your own strong random value, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
ESIM_ACCESS_WEBHOOK_SECRET=replace-with-strong-random-secret

# --- FIB payments (optional) ---
FIB_PAYMENT_CLIENT_ID=
FIB_PAYMENT_CLIENT_SECRET=
FIB_PAYMENT_WEBHOOK_SECRET=
# MUST be set per-deployment: the public URL of THIS backend's FIB webhook
# endpoint (https://<your-host>/api/v1/payments/fib/webhook). There is no
# built-in default. If left empty while FIB credentials are set, the app still
# boots but logs an ERROR and payment confirmation relies on status polling.
FIB_PAYMENT_STATUS_CALLBACK_URL=

# --- Firebase push (provide file path OR inline JSON) ---
FIREBASE_SERVICE_ACCOUNT_FILE=
FIREBASE_SERVICE_ACCOUNT_JSON=
PUSH_NOTIFICATION_DEFAULT_CHANNEL_ID=general

# --- VerifyWay OTP (WhatsApp) ---
# Required for the /api/v1/otp/* endpoints (they return 503 if unset).
VERIFYWAY_API_KEY=
VERIFYWAY_BASE_URL=https://api.verifyway.com/api/v1/
# Delivery channel: whatsapp (default) or sms.
VERIFYWAY_CHANNEL=whatsapp
VERIFYWAY_TIMEOUT_SECONDS=30
# OTP behavior (defaults shown): code length, validity, resend cooldown, tries.
VERIFYWAY_OTP_LENGTH=4
VERIFYWAY_OTP_TTL_SECONDS=300
VERIFYWAY_OTP_RESEND_COOLDOWN_SECONDS=60
VERIFYWAY_OTP_MAX_ATTEMPTS=5

# --- WINGS flight availability ---
# Token is REQUIRED for the WINGS endpoints to work (they return 503 if unset).
# Set the *rotated* token here — the previously committed one is compromised.
WINGS_AUTH_TOKEN=
WINGS_BASE_URL=https://wings.laveen-air.com/RIAM_main/rest/api
# Optional explicit override; derived from WINGS_BASE_URL when blank.
WINGS_SEARCH_URL=
WINGS_REQUEST_TIMEOUT_SECONDS=60
